<protocol>

    <versions>
        <version name="FIXT_1_1" code="FIXT.1.1"/>
        <version name="FIX_4_3" code="FIX.4.3"/>
        <version name="FIX_4_4" code="FIX.4.4"/>
    </versions>

    <types>
        <type name="String8" primitiveType="char" length="8"/>

        <enum name="Encryption">
            <element name="None" value="0"/>
        </enum>

        <enum name="MessageType">
            <element name="Logon" value="A"/>
            <element name="Logout" value="5"/>
            <element name="TestRequest" value="1"/>
            <element name="Heartbeat" value="0"/>
            <element name="ResendRequest" value="2"/>
            <element name="Reject" value="3"/>
            <element name="SequenceReset" value="4"/>
            <element name="NewOrderSingle" value="D"/>
            <element name="ExecutionReport" value="8"/>
        </enum>

        <enum name="SessionRejectReason">
            <element name="InvalidTagNumber" value="0"/>
            <element name="RequiredTagMissing" value="1"/>
            <element name="TagNotDefinedForMessageType" value="2"/>
            <element name="UndefinedTag" value="3"/>
            <element name="TagSpecifiedWithoutValue" value="4"/>
            <element name="ValueIsIncorrect" value="5"/>
            <element name="IncorrectDataFormat" value="6"/>
            <element name="DecryptionProblem" value="7"/>
            <element name="SignatureProblem" value="8"/>
            <element name="CompIDProblem" value="9"/>
            <element name="SendingTimeAccuracyProblem" value="10"/>
            <element name="InvalidMsgType" value="11"/>
        </enum>

        <enum name="GapFillFlag">
            <element name="GapFillMessage" value="Y"/>
            <element name="SequenceReset" value="N"/>
        </enum>

        <enum name="Side">
            <element name="Buy" value="1"/>
            <element name="Sell" value="2"/>
            <element name="BuyMinus" value="3"/>
            <element name="SellPlus" value="4"/>
            <element name="SellShort" value="5"/>
        </enum>

        <enum name="OrdType">
            <element name="Market" value="1"/>
            <element name="Limit" value="2"/>
            <element name="Stop" value="3"/>
            <element name="StopLimit" value="4"/>
        </enum>

        <enum name="TimeInForce">
            <element name="Day" value="0"/>
            <element name="GoodTillCancel" value="1"/>
            <element name="AtTheOpening" value="2"/>
            <element name="ImmediateOrCancel" value="3"/>
            <element name="FillOrKill" value="4"/>
        </enum>

        <enum name="HandlInst">
            <element name="AutoPrivate" value="1"/>
            <element name="AutoPublic" value="2"/>
            <element name="Manual" value="3"/>
        </enum>

        <enum name="ExecType">
            <element name="New" value="0"/>
            <element name="DoneForDay" value="3"/>
            <element name="Canceled" value="4"/>
            <element name="Replaced" value="5"/>
            <element name="PendingCancel" value="6"/>
            <element name="Stopped" value="7"/>
            <element name="Rejected" value="8"/>
            <element name="Suspended" value="9"/>
            <element name="PendingNew" value="A"/>
            <element name="Calculated" value="B"/>
            <element name="Expired" value="C"/>
            <element name="Restated" value="D"/>
            <element name="PendingReplace" value="E"/>
            <element name="Trade" value="F"/>
            <element name="TradeCorrect" value="G"/>
            <element name="TradeCancel" value="H"/>
            <element name="OrderStatus" value="I"/>
        </enum>

        <enum name="OrdStatus">
            <element name="New" value="0"/>
            <element name="PartiallyFilled" value="1"/>
            <element name="Filled" value="2"/>
            <element name="DoneForDay" value="3"/>
            <element name="Canceled" value="4"/>
            <element name="Replaced" value="5"/>
            <element name="PendingCancel" value="6"/>
            <element name="Stopped" value="7"/>
            <element name="Rejected" value="8"/>
            <element name="Suspended" value="9"/>
            <element name="PendingNew" value="A"/>
            <element name="Calculated" value="B"/>
            <element name="Expired" value="C"/>
            <element name="PendingReplace" value="E"/>
        </enum>

        <enum name="Boolean">
            <element name="Yes" value="Y"/>
            <element name="No" value="N"/>
        </enum>

    </types>

    <component name="NestedComp">
        <field name="NestedOne" tag="601" primitiveType="uint32" length="8" presence="optional"/>
        <field name="NestedTwo" tag="602" primitiveType="uint32" presence="optional"/>
    </component>

    <component name="StandardHeader">
        <!-- <field name="BeginString" tag="8" primitiveType="char" length="7" presence="constant">FIX.4.3</field> -->
        <field name="BeginString" tag="8" type="Protocol"/>
        <field name="BodyLength" tag="9" primitiveType="uint32"/>
        <field name="MsgType" tag="35" type="MessageType"/>

        <field name="Sender" tag="49" primitiveType="string" length="8"/>
        <field name="Target" tag="56" primitiveType="string" length="8"/>
        <field name="SequenceNumber" tag="34" primitiveType="uint32"/>
        <field name="SendingTime" tag="52" primitiveType="timestamp"/>
        <group name="Hops" tag="627" counter="NoHops" presence="optional" primitiveType="uint32">
            <field name="HopCompID" tag="628" primitiveType="string" length="8" presence="optional"/>
            <field name="HopSendingTime" tag="629" primitiveType="timestamp" presence="optional"/>
            <field name="HopRefID" tag="630" primitiveType="uint32" presence="optional"/>
            <group name="NestedGroup" tag="500" counter="NoTests" presence="optional" primitiveType="uint32">
                <field name="Name" tag="501" primitiveType="string" length="10"/>
                <field name="Comp" type="NestedComp"/>
            </group>
        </group>
    </component>

    <message name="Logon" id="A">
        <field name="Header" type="StandardHeader"/>
        <field name="EncryptMethod" tag="98" type="Encryption" presence="optional"/>
        <field name="HeartbeatInterval" tag="108" primitiveType="uint32"/>
        <data name="XmlData" tag="212" counter="XmlDataLen" lengthTag="212" presence="optional">
            <field name="Xml" tag="213" primitiveType="char"/>
        </data>
    </message>

    <message name="Logout" id="5">
        <field name="Header" type="StandardHeader"/>
        <field name="Text" tag="58" primitiveType="char" length="8" presence="optional"/>
    </message>

    <message name="Heartbeat" id="0">
        <field name="Header" type="StandardHeader"/>
        <field name="TestReqID" tag="112" primitiveType="char" length="32" presence="optional"/>
    </message>

    <message name="TestRequest" id="1">
        <field name="Header" type="StandardHeader"/>
        <field name="TestReqID" tag="112" primitiveType="char" length="32" presence="optional"/>
    </message>

    <message name="ResendRequest" id="2">
        <field name="Header" type="StandardHeader"/>
        <field name="BeginSeqNo" tag="7" primitiveType="uint32"/>
        <field name="EndSeqNo" tag="16" primitiveType="uint32"/>
    </message>

    <message name="Reject" id="3">
        <field name="Header" type="StandardHeader"/>
        <field name="RefSeqNum" tag="45" primitiveType="uint32"/>
        <field name="RefTagID" tag="371" primitiveType="uint32" presence="optional"/>
        <field name="RefMsgType" tag="372" type="MessageType" presence="optional"/>
        <field name="SessionRejectReason" tag="373" type="SessionRejectReason" presence="optional"/>
        <field name="Text" tag="58" primitiveType="string" length="64" presence="optional"/>
    </message>

    <message name="SequenceReset" id="4">
        <field name="Header" type="StandardHeader"/>
        <field name="GapFillFlag" tag="123" type="GapFillFlag" presence="optional"/>
        <field name="NewSeqNo" tag="36" primitiveType="uint32"/>
    </message>

    <message name="ExecutionReport" id="8">
        <field name="Header" type="StandardHeader"/>
        <field name="OrderID" tag="37" primitiveType="string" length="20"/>
        <field name="ClOrdID" tag="11" primitiveType="string" length="20" presence="optional"/>
        <field name="ExecID" tag="17" primitiveType="string" length="20"/>
        <field name="ExecType" tag="150" type="ExecType"/>
        <field name="OrdStatus" tag="39" type="OrdStatus"/>
        <field name="Symbol" tag="55" primitiveType="string" length="8"/>
        <field name="Side" tag="54" type="Side"/>
        <field name="OrderQty" tag="38" primitiveType="uint32" presence="optional"/>
        <field name="Price" tag="44" primitiveType="decimal" presence="optional"/>
        <field name="LastQty" tag="32" primitiveType="uint32" presence="optional"/>
        <field name="LastPx" tag="31" primitiveType="decimal" presence="optional"/>
        <field name="LeavesQty" tag="151" primitiveType="uint32"/>
        <field name="CumQty" tag="14" primitiveType="uint32"/>
        <field name="AvgPx" tag="6" primitiveType="decimal"/>
        <field name="TransactTime" tag="60" primitiveType="timestamp"/>
        <field name="Text" tag="58" primitiveType="string" length="64" presence="optional"/>
    </message>

    <message name="NewOrderSingle" id="D">
        <field name="Header" type="StandardHeader"/>
        <field name="Account" tag="1" primitiveType="string" length="8" presence="optional"/>
        <field name="ClOrdID" tag="11" primitiveType="string" length="20"/>
        <field name="HandlInst" tag="21" type="HandlInst"/>
        <field name="Symbol" tag="55" primitiveType="string" length="8"/>
        <field name="Side" tag="54" type="Side"/>
        <field name="TransactTime" tag="60" primitiveType="timestamp"/>
        <field name="OrderQty" tag="38" primitiveType="uint32"/>
        <field name="OrdType" tag="40" type="OrdType"/>
        <field name="Price" tag="44" primitiveType="decimal" presence="optional"/>
        <field name="TimeInForce" tag="59" type="TimeInForce" presence="optional"/>
        <field name="Text" tag="58" primitiveType="string" length="64" presence="optional"/>
        <field name="TradeDate" tag="75" primitiveType="dateonly" presence="optional"/>
        <field name="MaturityTime" tag="1079" primitiveType="timeonly" presence="optional"/>
    </message>

</protocol>
